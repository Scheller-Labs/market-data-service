# ============================================================
# Market Data Service — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Provider API Keys ─────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day
ALPHA_VANTAGE_API_KEY=

# Finnhub: https://finnhub.io/dashboard
# Free tier: 60 calls/min
FINNHUB_API_KEY=

# Databento: https://databento.com/portal
# Paid, usage-based — leave blank to disable
DATABENTO_API_KEY=

# ── Storage ───────────────────────────────────────────────
TIMESCALE_URL=postgresql://mds:mds_secret@localhost:5432/market_data
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mds
MINIO_SECRET_KEY=mds_secret
MINIO_BUCKET=market-data
MINIO_SECURE=false

# ── Coverage Manifest ─────────────────────────────────────
# SQLite file path — will be created automatically
COVERAGE_DB_PATH=/data/manifest/coverage.db

# ── Provider Defaults ────────────────────────────────────
# Which provider to use first for each data type
MDS_DEFAULT_PROVIDER_OHLCV=alpha_vantage
MDS_DEFAULT_PROVIDER_OPTIONS=finnhub
MDS_DEFAULT_PROVIDER_FUNDAMENTALS=alpha_vantage
MDS_DEFAULT_PROVIDER_NEWS=finnhub
MDS_DEFAULT_PROVIDER_TICK=databento

# ── Cache TTLs (seconds) ──────────────────────────────────
MDS_CACHE_TTL_REALTIME=60
MDS_CACHE_TTL_INTRADAY=300
MDS_CACHE_TTL_EOD=86400
MDS_CACHE_TTL_FUNDAMENTALS=604800   # 7 days

# ── Behavior ──────────────────────────────────────────────
MDS_LOG_LEVEL=INFO
MDS_DRY_RUN=false        # Set true to log what would be fetched without calling APIs
MDS_MAX_BATCH_WORKERS=4
MDS_REQUEST_TIMEOUT=30
MDS_MAX_RETRIES=3
